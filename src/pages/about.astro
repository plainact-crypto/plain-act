---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { site } from '../data/site.js';
const base = import.meta.env.BASE_URL;
const organizationSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Plain Act',
  alternateName: 'PlainAct Publishing',
  url: site.fullUrl,
  logo: new URL(`${base}${site.logo.replace(/^\//, '')}`, site.siteUrl).toString(),
  email: site.email,
  ...(site.sameAs.length ? { sameAs: site.sameAs } : {})
};
---
<BaseLayout title="About Plain Act | PlainAct Publishing" description="Official identity page for Plain Act and PlainAct Publishing, including author bio and contact email." path="/about/" current="About" schema={[organizationSchema]}>
  <section class="section"><div class="container grid grid-2">
    <div>
      <Breadcrumbs items={[{name:'Home', url:'/'}, {name:'About', url:'/about/'}]} />
      <p class="eyebrow">About</p><h1>Plain Act is a publishing identity, not a personal biography.</h1>
      <p>Plain Act publishes quiet management manuals for people carrying authority under pressure.</p>
      <p>Its books focus on practical judgment, restraint, communication, feedback, delegation, and decision timing — the parts of management that often become difficult before many people feel fully ready.</p>
      <p>Plain Act is written for first-time managers, newly promoted team leads, supervisors, and middle managers who need clear tools without hype, inflated leadership language, or motivational performance.</p>
      <p>The goal is simple: to give readers a calmer way to carry responsibility, reduce overreaction, and see the next useful action more clearly.</p>
    </div>
    <aside class="card">
      <h2>Official details</h2>
      <p>Publisher: PlainAct Publishing</p>
      <p>Email: <a href={`mailto:${site.email}`}>{site.email}</a></p>
      <p><a href={new URL('books/', site.fullUrl).toString()}>Plain Act books</a></p>
      <p><a href={new URL('contact/', site.fullUrl).toString()}>Contact and verification</a></p>
    </aside>
  </div></section>
</BaseLayout>
