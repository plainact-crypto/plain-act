---
import BaseLayout from '../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
const href = (url) => {
  if (url.startsWith('http')) return url;
  const cleanBase = base.endsWith('/') ? base.slice(0, -1) : base;
  const cleanUrl = url.startsWith('/') ? url : `/${url}`;
  return `${cleanBase}${cleanUrl}`;
};


const bookUrl = href('/books/the-first-30-days-as-a-new-manager/');
const resourcesUrl = href('/resources/');
const articlesUrl = href('/articles/');
const checklist = [["Day 1: Do not perform authority.", "Keep the opening calm. Do not overtalk, overpromise, or make a speech before you understand the work."], ["Meet each direct report.", "Ask what is working, what is stuck, and what they would change if they were in your role."], ["Map repeated problems.", "Do not react to the loudest issue. Look for patterns that repeat across conversations."], ["Pick one early improvement.", "Choose one small change that creates relief without disrupting the whole system."], ["Define your meeting rules.", "Start on time, end on time, capture blockers, and send short recaps."], ["Use clean decision sentences.", "Lead with the decision, not the backstory. Add context only when needed."], ["Delegate one low-risk task.", "Define the outcome, constraints, checkpoint, and then do not hover."], ["Give one narrow piece of feedback.", "Use observation, impact, and next step. Keep it factual and private."], ["Protect capacity.", "Pause before saying yes. Name trade-offs instead of absorbing everything."], ["Set boundaries with former peers.", "Stay warm, but separate friend lane from manager lane."], ["Send a weekly update upward.", "Progress, risk, ask, next. Short and steady beats impressive."], ["Review the first 30 days.", "What became clearer? What is still unstable? What needs a standard, not a speech?"]];
const schema = { '@context': 'https://schema.org', '@type': 'HowTo', name: 'First 30 Days as a New Manager Checklist', description: 'A practical checklist for first-time managers during the first 30 days after promotion.' };
---
<BaseLayout title="First 30 Days as a New Manager Checklist | Plain Act" description="A practical first 30 days checklist for new managers: authority, feedback, delegation, meetings, boundaries, and managing up." path="/resources/new-manager-checklist/" schema={[schema]}>
  <main class="plain-page"><header class="plain-hero"><p class="kicker">Checklist</p><h1>First 30 days as a new manager checklist.</h1><p>A practical checklist for first-time managers who need a calm operating rhythm in the first month after promotion.</p><div class="actions"><a href={bookUrl}>Read the book</a><a href={articlesUrl}>Articles</a><a href={resourcesUrl}>Resources</a></div></header><section class="content-grid"><article class="main-card"><h2>Use this as a working checklist</h2><div class="checklist">{checklist.map(([title, text]) => (<div class="check-item"><strong>□ {title}</strong><p>{text}</p></div>))}</div></article><aside class="side-card"><h2>Rule</h2><p>Do not use the first 30 days to prove yourself through motion. Use them to create stable signals.</p><ul><li>Observe before changing.</li><li>Speak less under pressure.</li><li>Make standards visible.</li><li>Follow through quietly.</li></ul></aside></section></main>
</BaseLayout>

<style>
  .plain-page { max-width: 1040px; margin: 0 auto; padding: 3rem 1.2rem 4rem; }
  .plain-hero { max-width: 820px; margin-bottom: 2rem; }
  .kicker { margin: 0 0 0.65rem; color: var(--accent); font-size: 0.78rem; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 700; }
  .plain-hero h1 { margin: 0; font-size: clamp(2.2rem, 5vw, 4.35rem); line-height: 0.96; letter-spacing: -0.06em; }
  .plain-hero p { margin-top: 1rem; color: var(--muted); font-size: 1.05rem; line-height: 1.7; }
  .actions { display: flex; flex-wrap: wrap; gap: 0.7rem; margin-top: 1.2rem; }
  .actions a, .text-card a { color: var(--text); text-decoration: none; border: 1px solid var(--border); border-radius: 999px; padding: 0.55rem 0.85rem; font-size: 0.9rem; background: rgba(255,255,255,.035); }
  .actions a:first-child { color: var(--accent); }
  .content-grid { display: grid; grid-template-columns: minmax(0, 1.4fr) minmax(260px, .6fr); gap: 1rem; align-items: start; }
  .main-card, .side-card, .text-card, .quote-card, .faq-card { border: 1px solid var(--border); border-radius: 1.15rem; background: rgba(255,255,255,.035); padding: 1.15rem; box-shadow: 0 24px 70px rgba(0,0,0,.16); }
  .main-card h2, .side-card h2, .text-card h2, .faq-card h2 { margin-top: 0; font-size: clamp(1.35rem, 2.5vw, 2rem); letter-spacing: -0.035em; }
  .main-card h3, .text-card h3 { margin-top: 1.55rem; margin-bottom: .45rem; }
  .main-card p, .main-card li, .side-card p, .side-card li, .text-card p, .text-card li, .faq-card p { color: var(--muted); line-height: 1.75; font-size: 0.98rem; }
  .main-card strong, .text-card strong { color: var(--text); }
  .list-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .9rem; }
  .text-card { min-height: 100%; }
  .quote-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .9rem; }
  .quote-card blockquote { margin: 0; color: var(--text); font-size: 1.08rem; line-height: 1.55; letter-spacing: -0.02em; }
  .quote-card p { color: var(--muted); margin-bottom: 0; font-size: .9rem; }
  .checklist { display: grid; gap: .75rem; }
  .check-item { border: 1px solid var(--border); border-radius: .95rem; padding: .9rem; background: rgba(255,255,255,.025); }
  .check-item strong { display: block; margin-bottom: .35rem; }
  .check-item p { margin: 0; }
  .faq-list { display: grid; gap: .9rem; }
  .faq-card h2 { margin-bottom: .35rem; }
  @media (max-width: 860px) { .content-grid, .list-grid, .quote-grid { grid-template-columns: 1fr; } .plain-page { padding-top: 2rem; } }
</style>
