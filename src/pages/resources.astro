---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
const resources = ['New Manager Pressure Checklist', 'First 30 Days Reflection Sheet', 'Delegation Reset Worksheet', 'Feedback Preparation Card'];
---
<BaseLayout title="Resources | Plain Act" description="Future Plain Act resource hub for new managers and readers. Resources are in development." path="/resources/" current="Resources">
  <section class="section"><div class="container">
    <Breadcrumbs items={[{name:'Home', url:'/'}, {name:'Resources', url:'/resources/'}]} />
    <p class="eyebrow">Resources</p><h1>Resources are in development.</h1>
    <p class="lede">This page will hold practical reader resources when they are ready. No downloadable files are currently published.</p>
    <div class="grid grid-2">{resources.map((r) => <article class="card development-card"><h2>{r}</h2><p>Planned resource. Details will be announced later.</p></article>)}</div>
  </div></section>
</BaseLayout>
