---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
const base = import.meta.env.BASE_URL;
const href = (url) => `${base}${url.replace(/^\//, '')}`;
const pages = [
  ['Home', '/'], ['Books', '/books/'], ['The First 30 Days', '/books/the-first-30-days-as-a-new-manager/'], ['Book Summary', '/books/the-first-30-days-as-a-new-manager/summary/'], ['Key Ideas', '/books/the-first-30-days-as-a-new-manager/key-ideas/'], ['Quotes', '/books/the-first-30-days-as-a-new-manager/quotes/'], ['DO THE WORK', '/books/do-the-work/'], ['Coming Soon', '/coming-soon/'], ['Method', '/method/'], ['About', '/about/'], ['Contact', '/contact/'], ['FAQ', '/faq/'], ['Resources', '/resources/'], ['New Manager Guide', '/guides/new-manager/'], ['New Manager Checklist', '/resources/new-manager-checklist/'], ['Affiliate Disclosure', '/affiliate-disclosure/'],
  ['Articles', '/articles/'], ['Why New Managers Overexplain Under Pressure', '/articles/why-new-managers-overexplain/'], ['How to Delegate Without Micromanaging', '/articles/delegate-without-micromanaging/'], ['Why First-Time Managers Struggle to Give Feedback', '/articles/feedback-without-killing-morale/'], ['How New Managers Can Build Authority Without Being Harsh', '/articles/build-authority-as-new-manager/'], ['Why New Managers Say Yes to Everything', '/articles/new-managers-say-yes/'], ['How to Manage Up Without Sounding Insecure', '/articles/manage-up-without-sounding-insecure/'], ['Why New Managers Avoid Difficult Conversations', '/articles/difficult-conversations-new-manager/'], ['How to Run Your First Team Meeting', '/articles/first-team-meeting-new-manager/'], ['Why New Managers Try to Fix Everything in Week One', '/articles/fix-everything-week-one/'], ['How to Set Boundaries With Former Peers After Promotion', '/articles/boundaries-former-peers/'],
];
---
<BaseLayout title="Sitemap | Plain Act" description="Human-readable sitemap for the Plain Act website." path="/sitemap/">
  <section class="section"><div class="container"><Breadcrumbs items={[{ name: 'Home', url: '/' }, { name: 'Sitemap', url: '/sitemap/' }]} /><p class="eyebrow">Sitemap</p><h1>Plain Act sitemap</h1><ul class="list-clean">{pages.map(([label, url]) => (<li><a href={href(url)}>{label}</a></li>))}</ul></div></section>
</BaseLayout>
