---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
const base = import.meta.env.BASE_URL;
const href = (url) => `${base}${url.replace(/^\//, '')}`;
const pages = [
  ['Home', '/'], ['Books', '/books/'], ['The First 30 Days', '/books/the-first-30-days-as-a-new-manager/'], ['DO THE WORK', '/books/do-the-work/'], ['Coming Soon', '/coming-soon/'], ['Method', '/method/'], ['About', '/about/'], ['Contact', '/contact/'], ['Resources', '/resources/'], ['New Manager Guide', '/guides/new-manager/']
];
---
<BaseLayout title="Sitemap | Plain Act" description="Human-readable sitemap for the Plain Act website." path="/sitemap/">
  <section class="section"><div class="container">
    <Breadcrumbs items={[{name:'Home', url:'/'}, {name:'Sitemap', url:'/sitemap/'}]} />
    <p class="eyebrow">Sitemap</p><h1>Plain Act sitemap</h1>
    <ul class="list-clean">{pages.map(([label, url]) => <li><a href={href(url)}>{label}</a></li>)}</ul>
  </div></section>
</BaseLayout>
