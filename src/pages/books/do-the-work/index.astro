---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../../components/Breadcrumbs.astro';
import { books } from '../../../data/books.js';
const book = books[1];
const base = import.meta.env.BASE_URL;
const href = (url) => `${base}${url.replace(/^\//, '')}`;
---
<BaseLayout title="DO THE WORK | Plain Act" description="Status page for DO THE WORK, an in-development Plain Act manual with metadata pending." path="/books/do-the-work/" current="Books">
  <section class="section">
    <div class="container">
      <Breadcrumbs items={[{name:'Home', url:'/'}, {name:'Books', url:'/books/'}, {name:'DO THE WORK', url:'/books/do-the-work/'}]} />
      <div class="grid grid-2">
        <div>
          <p class="eyebrow">In development / metadata pending</p>
          <h1>{book.title}</h1>
          <p class="lede">{book.subtitle}</p>
          <p>{book.description}</p>
          <p class="notice">This page is maintained only to keep Plain Act catalog status clear. No availability, ISBN, ASIN, cover, or retail link is displayed until final public details are confirmed.</p>
        </div>
        <aside class="card flat">
          <h2>Current status</h2>
          <table class="table">
            <tbody>
              <tr><th>Status</th><td>{book.status}</td></tr>
              <tr><th>Author</th><td>{book.author}</td></tr>
              <tr><th>Publisher</th><td>{book.publisher}</td></tr>
              <tr><th>Availability</th><td>Not listed on this site until confirmed.</td></tr>
              <tr><th>Metadata</th><td>Pending final confirmation.</td></tr>
            </tbody>
          </table>
        </aside>
      </div>
      <div class="button-row"><a class="button quiet" href={href('/books/')}>Back to catalog</a></div>
    </div>
  </section>
</BaseLayout>
