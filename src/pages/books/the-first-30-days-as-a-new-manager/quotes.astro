---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;
const href = (url) => {
  if (url.startsWith('http')) return url;
  const cleanBase = base.endsWith('/') ? base.slice(0, -1) : base;
  const cleanUrl = url.startsWith('/') ? url : `/${url}`;
  return `${cleanBase}${cleanUrl}`;
};


const bookUrl = href('/books/the-first-30-days-as-a-new-manager/');
const articlesUrl = href('/articles/');
const quotes = ["Authority is not a personality. Authority is a pattern.", "Overexplaining feels like clarity. It is usually anxiety.", "A clear decision followed by too much explanation becomes weaker.", "The team does not need your entire thought process. It needs the stable part of it.", "Feedback does not have to feel good. It has to be clear.", "Delegation is not disappearing. It is transferring ownership with a finish line.", "Do not fix what you do not understand yet.", "Every yes costs capacity.", "Warm always. Soft never.", "The first meeting is not a speech. It is a signal.", "Difficult conversations do not get easier with time. They get more expensive.", "The first 30 days are not for proving yourself. They are for becoming reliable."];
const schema = { '@context': 'https://schema.org', '@type': 'CollectionPage', name: 'Quotes from The First 30 Days as a New Manager', description: 'Shareable management quotes from the Plain Act book and article series.' };
---
<BaseLayout title="Quotes from The First 30 Days as a New Manager | Plain Act" description="Shareable quotes about authority, feedback, delegation, and early management pressure from Plain Act." path="/books/the-first-30-days-as-a-new-manager/quotes/" schema={[schema]}>
  <main class="plain-page"><header class="plain-hero"><p class="kicker">Quotes</p><h1>Plain Act quotes for new managers.</h1><p>Short, serious lines from the Plain Act approach to early management pressure. Use them as reminders, social captions, or internal notes.</p><div class="actions"><a href={bookUrl}>Open the book page</a><a href={articlesUrl}>Read articles</a></div></header><section class="quote-grid">{quotes.map((quote) => (<article class="quote-card"><blockquote>“{quote}”</blockquote><p>Plain Act — The First 30 Days as a New Manager</p></article>))}</section></main>
</BaseLayout>

<style>
  .plain-page { max-width: 1040px; margin: 0 auto; padding: 3rem 1.2rem 4rem; }
  .plain-hero { max-width: 820px; margin-bottom: 2rem; }
  .kicker { margin: 0 0 0.65rem; color: var(--accent); font-size: 0.78rem; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 700; }
  .plain-hero h1 { margin: 0; font-size: clamp(2.2rem, 5vw, 4.35rem); line-height: 0.96; letter-spacing: -0.06em; }
  .plain-hero p { margin-top: 1rem; color: var(--muted); font-size: 1.05rem; line-height: 1.7; }
  .actions { display: flex; flex-wrap: wrap; gap: 0.7rem; margin-top: 1.2rem; }
  .actions a, .text-card a { color: var(--text); text-decoration: none; border: 1px solid var(--border); border-radius: 999px; padding: 0.55rem 0.85rem; font-size: 0.9rem; background: rgba(255,255,255,.035); }
  .actions a:first-child { color: var(--accent); }
  .content-grid { display: grid; grid-template-columns: minmax(0, 1.4fr) minmax(260px, .6fr); gap: 1rem; align-items: start; }
  .main-card, .side-card, .text-card, .quote-card, .faq-card { border: 1px solid var(--border); border-radius: 1.15rem; background: rgba(255,255,255,.035); padding: 1.15rem; box-shadow: 0 24px 70px rgba(0,0,0,.16); }
  .main-card h2, .side-card h2, .text-card h2, .faq-card h2 { margin-top: 0; font-size: clamp(1.35rem, 2.5vw, 2rem); letter-spacing: -0.035em; }
  .main-card h3, .text-card h3 { margin-top: 1.55rem; margin-bottom: .45rem; }
  .main-card p, .main-card li, .side-card p, .side-card li, .text-card p, .text-card li, .faq-card p { color: var(--muted); line-height: 1.75; font-size: 0.98rem; }
  .main-card strong, .text-card strong { color: var(--text); }
  .list-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .9rem; }
  .text-card { min-height: 100%; }
  .quote-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .9rem; }
  .quote-card blockquote { margin: 0; color: var(--text); font-size: 1.08rem; line-height: 1.55; letter-spacing: -0.02em; }
  .quote-card p { color: var(--muted); margin-bottom: 0; font-size: .9rem; }
  .checklist { display: grid; gap: .75rem; }
  .check-item { border: 1px solid var(--border); border-radius: .95rem; padding: .9rem; background: rgba(255,255,255,.025); }
  .check-item strong { display: block; margin-bottom: .35rem; }
  .check-item p { margin: 0; }
  .faq-list { display: grid; gap: .9rem; }
  .faq-card h2 { margin-bottom: .35rem; }
  @media (max-width: 860px) { .content-grid, .list-grid, .quote-grid { grid-template-columns: 1fr; } .plain-page { padding-top: 2rem; } }
</style>
