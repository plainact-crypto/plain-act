---
import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../data/site.js';

const base = import.meta.env.BASE_URL;
const href = (url) => {
  if (url.startsWith('http')) return url;
  const cleanBase = base.endsWith('/') ? base.slice(0, -1) : base;
  const cleanUrl = url.startsWith('/') ? url : `/${url}`;
  return `${cleanBase}${cleanUrl}`;
};

const bookUrl = href('/books/the-first-30-days-as-a-new-manager/');
const resourcesUrl = href('/resources/');
const articles = [
  {
    "number": "01",
    "title": "Why New Managers Overexplain Under Pressure and How to Fix It",
    "slug": "/articles/why-new-managers-overexplain/",
    "topic": "Communication",
    "meta_desc": "New managers often overexplain to sound competent. Learn why it weakens authority and how to communicate with more restraint.",
    "hasVideo": true,
    "long_embed": "https://www.youtube.com/embed/ZC7cIHJPhho",
    "long_watch": "https://youtu.be/ZC7cIHJPhho",
    "shorts": [
      {
        "watch": "https://youtube.com/shorts/9thjZ3fbRvs",
        "embed": "https://www.youtube.com/embed/9thjZ3fbRvs"
      }
    ]
  },
  {
    "number": "02",
    "title": "How to Delegate Without Micromanaging as a New Manager",
    "slug": "/articles/delegate-without-micromanaging/",
    "topic": "Delegation",
    "meta_desc": "New managers either hoard work or hover. Learn a simple 4-step delegation method that builds trust and gets results.",
    "hasVideo": true,
    "long_embed": "https://www.youtube.com/embed/oWsC7tHsI38",
    "long_watch": "https://youtu.be/oWsC7tHsI38",
    "shorts": [
      {
        "watch": "https://youtube.com/shorts/a6_tVVRPPvA",
        "embed": "https://www.youtube.com/embed/a6_tVVRPPvA"
      },
      {
        "watch": "https://youtube.com/shorts/wf8nNnS0d4M",
        "embed": "https://www.youtube.com/embed/wf8nNnS0d4M"
      },
      {
        "watch": "https://youtube.com/shorts/CJrRZKdNQ38",
        "embed": "https://www.youtube.com/embed/CJrRZKdNQ38"
      }
    ]
  },
  {
    "number": "03",
    "title": "Why First-Time Managers Struggle to Give Feedback and How to Fix It",
    "slug": "/articles/feedback-without-killing-morale/",
    "topic": "Feedback",
    "meta_desc": "Avoiding feedback kills morale faster than giving it. A calm 3-line method for first-time managers to give clear feedback without guilt.",
    "hasVideo": false,
    "long_embed": null,
    "long_watch": null,
    "shorts": []
  },
  {
    "number": "04",
    "title": "How New Managers Can Build Authority Without Being Harsh",
    "slug": "/articles/build-authority-as-new-manager/",
    "topic": "Authority",
    "meta_desc": "Authority isn't loud. Learn how new managers can build quiet, steady authority in the first 30 days without being harsh or fake.",
    "hasVideo": false,
    "long_embed": null,
    "long_watch": null,
    "shorts": []
  },
  {
    "number": "05",
    "title": "Why New Managers Say Yes to Everything and Burn Out in 30 Days",
    "slug": "/articles/new-managers-say-yes/",
    "topic": "Capacity",
    "meta_desc": "Saying yes to everything feels like good leadership. It’s how new managers burn out by week three. Here’s how to protect capacity.",
    "hasVideo": false,
    "long_embed": null,
    "long_watch": null,
    "shorts": []
  },
  {
    "number": "06",
    "title": "How to Manage Up Without Sounding Insecure as a New Manager",
    "slug": "/articles/manage-up-without-sounding-insecure/",
    "topic": "Managing Up",
    "meta_desc": "New managers either go silent or over-explain to their boss. Learn a calm weekly update that builds trust without sounding insecure.",
    "hasVideo": false,
    "long_embed": null,
    "long_watch": null,
    "shorts": []
  },
  {
    "number": "07",
    "title": "Why New Managers Avoid Difficult Conversations and How to Stop",
    "slug": "/articles/difficult-conversations-new-manager/",
    "topic": "Conflict",
    "meta_desc": "Avoiding hard conversations doesn't keep the peace. It kills it. A simple script for new managers to address issues early and calmly.",
    "hasVideo": false,
    "long_embed": null,
    "long_watch": null,
    "shorts": []
  },
  {
    "number": "08",
    "title": "How to Run Your First Team Meeting Without Losing Control",
    "slug": "/articles/first-team-meeting-new-manager/",
    "topic": "Meetings",
    "meta_desc": "Your first team meeting sets the tone. A simple 30-minute agenda for new managers that builds authority without a big speech.",
    "hasVideo": false,
    "long_embed": null,
    "long_watch": null,
    "shorts": []
  },
  {
    "number": "09",
    "title": "Why New Managers Try to Fix Everything in Week One and Fail",
    "slug": "/articles/fix-everything-week-one/",
    "topic": "First Week",
    "meta_desc": "New managers rush to prove themselves by changing everything immediately. Here’s why that backfires, and what to do in week one instead.",
    "hasVideo": false,
    "long_embed": null,
    "long_watch": null,
    "shorts": []
  },
  {
    "number": "10",
    "title": "How to Set Boundaries With Former Peers After Promotion",
    "slug": "/articles/boundaries-former-peers/",
    "topic": "Peer Transition",
    "meta_desc": "Promoted over your friends? Learn how new managers can set clear, kind boundaries with former peers without losing trust.",
    "hasVideo": false,
    "long_embed": null,
    "long_watch": null,
    "shorts": []
  }
];

const schema = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Plain Act Articles',
  description: 'Practical management articles and video lessons for first-time managers.',
  url: new URL(`${base}articles/`, site.siteUrl).toString(),
  publisher: {
    '@type': 'Organization',
    name: 'Plain Act',
    url: site.siteUrl,
  },
  mainEntity: {
    '@type': 'ItemList',
    itemListElement: articles.map((article, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: article.title,
      url: new URL(`${base}${article.slug.replace(/^\//, '')}`, site.siteUrl).toString(),
    })),
  },
};
---

<BaseLayout
  title="Articles | Plain Act"
  description="Practical management articles and video lessons for first-time managers."
  path="/articles/"
  schema={[schema]}
>
  <section class="articles-shell">
    <header class="articles-top">
      <p class="kicker">Plain Act Articles</p>
      <h1>Management field notes.</h1>
      <p>
        Practical lessons for first-time managers carrying authority, feedback, delegation, and decision pressure.
      </p>
      <div class="top-actions">
        <a href={bookUrl}>Read the book</a>
        <a href={resourcesUrl}>Resources</a>
      </div>
    </header>

    <section class="video-strip" aria-label="Featured video articles">
      {articles.filter((article) => article.hasVideo).map((article) => (
        <article class="video-card">
          <div class="card-head">
            <span>{article.number}</span>
            <span>{article.topic}</span>
          </div>
          <h2>{article.title}</h2>
          <p>{article.meta_desc}</p>
          <div class="video-frame">
            <iframe
              src={article.long_embed}
              title={article.title}
              loading="lazy"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            ></iframe>
          </div>
          <div class="mini-actions">
            <a class="read-link" href={href(article.slug)}>▣ Read article</a>
            <a href={article.long_watch} target="_blank" rel="noreferrer">Watch on YouTube</a>
          </div>
        </article>
      ))}
    </section>

    <section class="directory" aria-label="All article titles">
      <div class="directory-head">
        <p class="kicker">Directory</p>
        <h2>Article list</h2>
      </div>

      <div class="article-grid">
        {articles.map((article) => (
          <article class="article-tile">
            <div class="tile-top">
              <span class="num">{article.number}</span>
              <span class="topic">{article.topic}</span>
            </div>
            <h3>{article.title}</h3>
            <p>{article.meta_desc}</p>
            <div class="tile-actions">
              <a class="read-link" href={href(article.slug)}>▣ Read</a>
              {article.hasVideo && <a href={article.long_watch} target="_blank" rel="noreferrer">▶ Video</a>}
            </div>
          </article>
        ))}
      </div>
    </section>
  </section>
</BaseLayout>

<style>
  .articles-shell {
    max-width: 1160px;
    margin: 0 auto;
    padding: 3.2rem 1.2rem 4rem;
  }

  .articles-top {
    max-width: 760px;
    margin-bottom: 2rem;
  }

  .kicker {
    margin: 0 0 0.65rem;
    color: var(--accent);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    font-weight: 700;
  }

  .articles-top h1 {
    margin: 0;
    font-size: clamp(2.1rem, 5vw, 4.2rem);
    line-height: 0.95;
    letter-spacing: -0.06em;
  }

  .articles-top p {
    margin: 1rem 0 0;
    max-width: 650px;
    color: var(--muted);
    font-size: 1.02rem;
    line-height: 1.65;
  }

  .top-actions,
  .mini-actions,
  .tile-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    align-items: center;
  }

  .top-actions {
    margin-top: 1.2rem;
  }

  .top-actions a,
  .mini-actions a,
  .tile-actions a {
    color: var(--text);
    text-decoration: none;
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.55rem 0.82rem;
    font-size: 0.88rem;
    background: rgba(255, 255, 255, 0.035);
  }

  .read-link {
    color: var(--accent) !important;
  }

  .video-strip {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
    margin: 2rem 0 2.5rem;
  }

  .video-card,
  .article-tile {
    border: 1px solid var(--border);
    border-radius: 1.2rem;
    background: rgba(255, 255, 255, 0.035);
    box-shadow: 0 24px 70px rgba(0, 0, 0, 0.18);
  }

  .video-card {
    padding: 1rem;
  }

  .card-head,
  .tile-top {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin-bottom: 0.8rem;
  }

  .card-head span,
  .topic {
    border: 1px solid var(--border);
    border-radius: 999px;
    padding: 0.22rem 0.55rem;
    color: var(--muted);
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .num {
    color: var(--accent);
    font-weight: 800;
    font-size: 0.9rem;
  }

  .video-card h2,
  .article-tile h3 {
    margin: 0;
    line-height: 1.15;
    letter-spacing: -0.025em;
  }

  .video-card h2 {
    font-size: clamp(1.25rem, 2.2vw, 1.75rem);
  }

  .article-tile h3 {
    font-size: 1.08rem;
  }

  .video-card p,
  .article-tile p {
    color: var(--muted);
    line-height: 1.55;
    font-size: 0.94rem;
  }

  .video-frame {
    position: relative;
    overflow: hidden;
    aspect-ratio: 16 / 9;
    border: 1px solid var(--border);
    border-radius: 0.85rem;
    background: #05070a;
    margin: 0.9rem 0;
  }

  .video-frame iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }

  .directory-head {
    margin-bottom: 1rem;
  }

  .directory-head h2 {
    margin: 0;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    letter-spacing: -0.04em;
  }

  .article-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.9rem;
  }

  .article-tile {
    padding: 1rem;
  }

  @media (max-width: 840px) {
    .video-strip,
    .article-grid {
      grid-template-columns: 1fr;
    }

    .articles-shell {
      padding-top: 2rem;
    }
  }
</style>
