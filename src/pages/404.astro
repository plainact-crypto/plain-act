---
import BaseLayout from '../layouts/BaseLayout.astro';
const base = import.meta.env.BASE_URL;
const href = (url) => `${base}${url.replace(/^\//, '')}`;
---
<BaseLayout title="Page not found | Plain Act" description="The requested Plain Act page could not be found." path="/404.html">
  <section class="section"><div class="container">
    <p class="eyebrow">404</p><h1>Page not found.</h1>
    <p class="lede">The page may have moved, or the link may be incomplete.</p>
    <div class="button-row"><a class="button" href={href('/')}>Home</a><a class="button secondary" href={href('/books/')}>Books</a></div>
  </div></section>
</BaseLayout>
